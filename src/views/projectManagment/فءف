     <div v-else-if="activeTab === 'Files'" class="flex flex-col gap-6">
        
        <!-- القائمة الرئيسية للمجلدات والملفات (اليسار) -->
        <div class="lg:col-span-2 bg-white border border-gray-100 rounded-2xl p-6 shadow-sm min-h-[450px]">
          
          <!-- Breadcrumb للتنقل داخل الفولدرات -->
          <div class="flex items-center gap-2 mb-6 text-xs text-gray-400">
            <span class="hover:text-slate-600 cursor-pointer" @click="currentFolderId = null">Root</span>
            <span v-if="currentFolderId">➔</span>
            <span class="text-slate-800 font-medium" v-if="currentFolderId">{{ currentPath }}</span>
            <button v-if="currentFolderId" @click="navigateBack" class="ml-auto text-[#2563EB] font-semibold hover:underline">➔ الرجوع للخلف</button>
          </div>

          <div class="space-y-4">
            <div v-for="item in displayedFiles" :key="item.id" 
              @click="navigateToFolder(item)"
              :class="['flex items-center justify-between p-3 rounded-xl border border-transparent transition-all group', item.isFolder ? 'hover:bg-slate-50 cursor-pointer' : 'hover:bg-gray-50']">
              
              <div class="flex items-center gap-4">
                <!-- الأيقونة المناسبة لكل نوع -->
                <div class="w-10 h-10 rounded-xl flex items-center justify-center">
                  <svg v-if="item.isFolder" class="w-6 h-6 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                  <svg v-else-if="item.type === 'pdf'" class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                  <svg v-else-if="item.type === 'figma'" class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <svg v-else class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 00-2 2z"/></svg>
                </div>

                <!-- تفاصيل الملف/الفولدر -->
                <div>
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-slate-800">{{ item.name }}</span>
                    <span v-if="item.isLocked" class="bg-red-50 text-red-600 text-[9px] font-bold px-1.5 py-0.5 rounded-md flex items-center gap-0.5">🔒 LOCKED</span>
                  </div>
                  <p class="text-xs text-gray-400 mt-0.5">
                    {{ item.isFolder ? `${item.fileCount} files • ${item.lastChanged}` : `${item.size} • ${item.details}` }}
                  </p>
                </div>
              </div>

              <!-- قائمة خيارات الملفات التفاعلية (•••) -->
              <div class="relative" @click.stop>
                <button @click="showFileMenu = showFileMenu === item.id ? null : item.id" class="p-1 rounded-lg hover:bg-gray-200 text-gray-400 hover:text-slate-700">
                  •••
                </button>
                <div v-if="showFileMenu === item.id" class="absolute right-0 top-8 bg-white border border-gray-100 shadow-xl rounded-xl py-1.5 w-32 z-30 text-xs font-medium">
                  <button v-if="!item.isFolder" @click="downloadFileItem(item)" class="w-full text-left px-4 py-2 hover:bg-gray-50 text-slate-700">Download</button>
                  <button @click="deleteFileItem(item.id)" class="w-full text-left px-4 py-2 hover:bg-red-50 text-red-500">Delete</button>
                </div>
              </div>
            </div>

            <!-- عرض حالة المجلد الفارغ -->
            <div v-if="displayedFiles.length === 0" class="text-center py-20 text-gray-400 text-sm">
              Folder is empty. Upload files or create a new folder inside!
            </div>
          </div>
        </div>

        <!-- الشريط الجانبي (تاريخ الإصدارات وحجم التخزين المستهلك - اليمين) -->
        <div class="space-y-6">
          <!-- Version History -->
          <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
            <h3 class="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
              <span class="text-gray-400">⏱</span> Version History
            </h3>
            <div class="relative border-l border-gray-100 pl-4 space-y-5 text-xs">
              <div v-for="log in versionHistory" :key="log.id" class="relative">
                <div class="absolute -left-[21px] top-1 w-2.5 h-2.5 rounded-full bg-slate-800 ring-4 ring-white"></div>
                <p class="text-gray-600 leading-normal">
                  <span class="font-semibold text-slate-800">{{ log.user }}</span> {{ log.action }} 
                  <span class="font-medium text-slate-800" v-if="log.target"><br>{{ log.target }}</span>
                </p>
                <span class="text-[10px] text-gray-400 font-bold block mt-1 tracking-wider">{{ log.time }}</span>
              </div>
            </div>
            <button class="w-full text-center text-xs font-semibold text-blue-500 hover:underline mt-5 block">
              View all audit logs
            </button>
          </div>

          <!-- Storage Status -->
          <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
            <div class="flex items-center justify-between text-xs font-bold uppercase tracking-wider mb-2">
              <span class="text-slate-700">Storage Status</span>
              <span class="text-slate-800">72% Used</span>
            </div>
            <div class="w-full bg-gray-100 h-2 rounded-full mb-3">
              <div class="bg-[#2563EB] h-2 rounded-full" style="width: 72%"></div>
            </div>
            <p class="text-[11px] text-gray-400 leading-normal">
              14.4 GB of 20 GB used across 4 repositories.
            </p>
          </div>
        </div>
      </div>










         <div v-if="activeTab === 'Milestones'"  class="flex flex-col gap-5">
        <!-- الخريطة الزمنية الأفقية العلوية -->
        <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
          <div class="relative flex items-center justify-between w-full max-w-4xl mx-auto py-6">
            <!-- خط الخلفية -->
            <div class="absolute left-0 right-0 h-[3px] bg-gray-100 top-[53px] z-0"></div>
            <!-- الخط الأزرق للمراحل المكتملة -->
            <div class="absolute left-0 w-[50%] h-[3px] bg-[#2563EB] top-[53px] z-0"></div>

            <!-- المرحلة الأولى -->
            <div class="relative z-10 flex flex-col items-center flex-1 text-center">
              <span class="text-[10px] font-bold uppercase text-blue-500 bg-blue-50 px-2.5 py-0.5 rounded-full mb-3">COMPLETE</span>
              <div class="w-10 h-10 rounded-full bg-[#2563EB] text-white flex items-center justify-center shadow-md mb-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-sm font-semibold text-slate-800">Phase 1: UX Research</span>
            </div>

            <!-- المرحلة الثانية -->
            <div class="relative z-10 flex flex-col items-center flex-1 text-center">
              <span class="text-[10px] font-bold uppercase text-white bg-[#2563EB] px-2.5 py-0.5 rounded-full mb-3">IN PROGRESS</span>
              <div class="w-10 h-10 rounded-full bg-white border-2 border-[#2563EB] text-[#2563EB] flex items-center justify-center shadow-md mb-2 font-bold">
                ✦
              </div>
              <span class="text-sm font-semibold text-slate-800">Phase 2: UI Design</span>
            </div>

            <!-- المرحلة الثالثة -->
            <div class="relative z-10 flex flex-col items-center flex-1 text-center">
              <span class="text-[10px] font-bold uppercase text-gray-400 bg-gray-100 px-2.5 py-0.5 rounded-full mb-3">PENDING</span>
              <div class="w-10 h-10 rounded-full bg-white border-2 border-gray-200 text-gray-300 flex items-center justify-center mb-2 font-mono text-sm">
                { }
              </div>
              <span class="text-sm font-semibold text-gray-400">Phase 3: Backend</span>
            </div>
          </div>

          <!-- بطاقات تفاصيل الـ Phases السفليّة -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
            <div v-for="ms in milestones" :key="ms.id" 
              class="border border-gray-100 bg-white rounded-xl p-5 hover:border-blue-200 transition-all flex flex-col justify-between">
              <div>
                <div class="flex items-center justify-between mb-3 text-xs">
                  <span :class="['font-semibold', ms.status === 'COMPLETE' ? 'text-blue-500' : ms.status === 'IN PROGRESS' ? 'text-[#2563EB]' : 'text-gray-400']">{{ ms.progressPct }}% Completed</span>
                  <span class="text-gray-400 font-medium">{{ ms.date }}</span>
                </div>
                <div class="w-full bg-gray-100 h-1.5 rounded-full mb-4">
                  <div class="bg-[#2563EB] h-1.5 rounded-full transition-all" :style="`width: ${ms.progressPct}%`"></div>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed mb-4">{{ ms.desc }}</p>
              </div>

              <!-- تذييل مخصص لكل بطاقة حسب الصورة -->
              <div class="pt-3 border-t border-gray-50 flex items-center justify-between">
                <div v-if="ms.avatars" class="flex -space-x-1">
                  <img v-for="av in ms.avatars" :src="av" class="w-5 h-5 rounded-full object-cover border border-white" />
                </div>
                <span v-if="ms.subtitle" class="text-[10px] font-bold text-gray-400 tracking-wider flex items-center gap-1">
                  ⏱ {{ ms.subtitle }}
                </span>
                <a v-if="ms.linkText" href="#" class="text-xs text-blue-500 font-medium hover:underline flex items-center gap-0.5">
                  {{ ms.linkText }} ➔
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- قسم التحليلات الجانبي والأسفل -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-slate-800">Team Velocity</span>
              <span class="text-green-500 text-xs">📈</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">24.5</div>
            <div class="text-[10px] text-gray-400 font-bold uppercase tracking-wider mt-0.5 mb-3">STORY POINTS / SPRINT</div>
            <div class="flex items-end gap-1 h-8">
              <div class="bg-blue-100 w-full rounded-sm" style="height: 30%"></div>
              <div class="bg-blue-200 w-full rounded-sm" style="height: 50%"></div>
              <div class="bg-blue-300 w-full rounded-sm" style="height: 75%"></div>
              <div class="bg-[#2563EB] w-full rounded-sm" style="height: 100%"></div>
            </div>
          </div>
          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm font-semibold text-slate-800">Risk Assessment</span>
              <span class="text-red-500 text-xs">⚠️</span>
            </div>
            <ul class="text-xs space-y-2">
              <li class="flex items-center justify-between"><span class="text-gray-500">Resource Allocation</span> <span class="text-blue-500 font-medium">(Low)</span></li>
              <li class="flex items-center justify-between"><span class="text-gray-500">Timeline Drift</span> <span class="text-gray-400 font-medium">(Neutral)</span></li>
              <li class="flex items-center justify-between"><span class="text-gray-500">External API Docs</span> <span class="text-red-500 font-medium">(High)</span></li>
            </ul>
          </div>
          <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm flex flex-col justify-between">
            <div>
              <span class="text-sm font-semibold text-slate-800">Project Health</span>
              <div class="text-3xl font-serif text-[#2563EB] mt-2">Excellent</div>
            </div>
            <div class="text-xs text-gray-400">All primary KPIs within 5% of target.</div>
          </div>
        </div>
      </div>
